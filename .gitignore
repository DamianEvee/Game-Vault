# ==========================================================
dist/
dist-ssr/
target/
src-tauri/target/

# ==========================================================
# Environment Variables
# ==========================================================
.env
.env.local
*.local

# ==========================================================
# Database Files (SQLite)
# ==========================================================
*.db
*.db-shm
*.db-wal
*.sqlite
*.sqlite3

# ==========================================================
# Logs
# ==========================================================
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ==========================================================
# IDE / Editors
# ==========================================================
.vscode/*
!.vscode/extensions.json
.idea/

# Visual Studio
*.suo
*.ntvs*
*.njsproj
*.sln

# Vim
*.sw?
*.swp
*.swo

# ==========================================================
# Operating System Files
# ==========================================================
.DS_Store
Thumbs.db

# ==========================================================
